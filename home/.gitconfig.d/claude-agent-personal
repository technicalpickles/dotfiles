# Agent git identity for Claude Code under DOTPICKLES_ROLE=personal.
# See doc/adr/0031-role-scoped-agent-git-identity.md.
#
# Referenced via GIT_CONFIG_GLOBAL in claude/roles/personal.jsonc. The
# [include] pulls in the real global gitconfig first (transitively pulling
# in gitconfig.d fragments via ~/.gitconfig's own includes). Later sections
# here override: user.email, core.sshCommand for the agent SSH key, and
# gpg.ssh.program=ssh-keygen to defeat the 1Password op-ssh-sign default.
[include]
	path = ~/.gitconfig
[user]
	email = joshua.nichols+personal-agent@gmail.com
	signingkey = ~/.ssh/agents/personal/id_ed25519.pub
[core]
	sshCommand = ssh -i ~/.ssh/agents/personal/id_ed25519 -o IdentitiesOnly=yes -o IdentityAgent=SSH_AUTH_SOCK
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	program = ssh-keygen
