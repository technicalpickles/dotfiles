#!/usr/bin/env bash
# claude-with - Run Claude Code with a named environment
#
# Each environment gets its own CLAUDE_CONFIG_DIR at
# ~/.local/share/claude-env/<name>/, with separate settings,
# permissions, history, and plugin state.
#
# On first use, auth settings (env vars, AWS auth) are copied
# from ~/.claude/settings.json so Claude Just Works.
#
# Usage:
#   claude-with <name> [claude-args...]   Run claude in named env
#   claude-with --list                    Show available environments
#   claude-with <name> --create [--bare]  Set up a new environment
#   claude-with <name> --clean            Remove env
#   claude-with <name> --path             Print env path and exit
#   claude-with <name> --settings         Dump env settings.json
#   claude-with <name> --merge-settings <json|file>  Deep merge into settings
#   claude-with --help                    Show this help
#
# What CLAUDE_CONFIG_DIR isolates (per-env, replaces ~/.claude/):
#   - settings.json (user-scope permissions, env vars, hooks, enabledPlugins)
#   - .claude.json (theme, onboarding state, user prefs)
#   - sessions/ and history
#   - plugins/ cache (installed marketplaces and plugin files)
#
# What still comes from the project working directory (.claude/):
#   - skills/ and commands/ (project skills always load from cwd)
#   - CLAUDE.md and rules/
#   - settings.json and settings.local.json (project-scope config)
#   - enabledPlugins in project-scope settings (plugins show "failed to
#     load" if enabled at project scope but not installed in the env)
#   - First run prompts for project trust (one-time per project per env)
#
# To install plugins in an env:
#   claude-with <name> -- plugin marketplace add <org>/<repo>
#   claude-with <name> -- plugin install <plugin>@<marketplace>

set -euo pipefail

ENV_BASE="${CLAUDE_ENV_BASE:-$HOME/.local/share/claude-env}"
GLOBAL_SETTINGS="$HOME/.claude/settings.json"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
NC='\033[0m'

log() { echo -e "${GREEN}[claude-with]${NC} $*"; }
warn() { echo -e "${YELLOW}[claude-with]${NC} $*"; }
err() { echo -e "${RED}[claude-with]${NC} $*" >&2; }

usage() {
  cat << 'EOF'
Usage: claude-with <name> [-- claude-args...]

Run Claude Code with a named, isolated environment.

Commands:
  claude-with <name> [-- claude-args]  Start Claude in named env
  claude-with <name> -- -p "prompt"    Pass args through to Claude
  claude-with <name> --create          Create a new environment
  claude-with <name> --create --bare   Create without copying auth settings
  claude-with <name> --clean           Remove the environment
  claude-with <name> --path            Print environment path
  claude-with <name> --settings        Dump current settings.json
  claude-with <name> --merge-settings <json|file>
                                       Deep merge into settings.json
  claude-with --list                   List available environments

Options:
  --help, -h    Show this help
  --            Stop processing claude-with options, pass rest to Claude

Environment variable:
  CLAUDE_ENV_BASE   Override base directory (default: ~/.local/share/claude-env)

Environments must be explicitly created with --create before use.
Auth settings are copied from ~/.claude/settings.json during creation
(use --bare to skip).
EOF
}

list_envs() {
  if [[ ! -d "$ENV_BASE" ]]; then
    echo "No environments yet."
    echo -e "${DIM}Create one: claude-with <name> --create${NC}"
    return
  fi

  local found=0
  for dir in "$ENV_BASE"/*/; do
    [[ -d "$dir" ]] || continue
    local name
    name=$(basename "$dir")
    local settings="$dir/settings.json"
    local detail=""
    if [[ -f "$settings" ]]; then
      detail=$(jq -r '
                [
                    (if .enabledPlugins then (.enabledPlugins | length | tostring) + " plugins" else empty end),
                    (if .permissions.allow then (.permissions.allow | length | tostring) + " allows" else empty end)
                ] | join(", ")
            ' "$settings" 2> /dev/null || true)
    fi
    if [[ -n "$detail" ]]; then
      echo -e "  ${GREEN}$name${NC}  ${DIM}($detail)${NC}"
    else
      echo -e "  ${GREEN}$name${NC}"
    fi
    found=1
  done

  if [[ $found -eq 0 ]]; then
    echo "No environments yet."
    echo -e "${DIM}Create one: claude-with <name> --create${NC}"
  fi
}

setup_env() {
  local env_dir="$1"
  local name="$2"
  local bare="$3"

  log "Creating environment '$name'..."
  mkdir -p "$env_dir"

  if [[ "$bare" == "true" ]]; then
    echo '{}' > "$env_dir/settings.json"
    log "Created bare environment (no auth settings)."
  elif [[ -f "$GLOBAL_SETTINGS" ]]; then
    # Extract auth-related settings from global config
    jq '{
            env: (.env // {}),
            awsAuthRefresh: .awsAuthRefresh,
            statusLine: .statusLine
        } | with_entries(select(.value != null))' "$GLOBAL_SETTINGS" > "$env_dir/settings.json"
    log "Copied auth settings from global config."
  else
    echo '{}' > "$env_dir/settings.json"
    warn "No global settings found, created empty config."
  fi

  # Skip onboarding prompts (theme picker, etc.)
  cat > "$env_dir/.claude.json" << 'EOF'
{
  "hasCompletedOnboarding": true,
  "hasSeenTasksHint": true,
  "theme": "dark",
  "numStartups": 0
}
EOF

  log "Environment ready at $env_dir"
}

dump_settings() {
  local env_dir="$1"
  local name="$2"
  local settings="$env_dir/settings.json"

  if [[ ! -f "$settings" ]]; then
    err "No settings.json in environment '$name'."
    exit 1
  fi

  cat "$settings"
}

merge_settings() {
  local env_dir="$1"
  local name="$2"
  local arg="$3"
  local settings="$env_dir/settings.json"

  if [[ ! -f "$settings" ]]; then
    err "No settings.json in environment '$name'."
    exit 1
  fi

  # Detect JSON vs file path: if first non-whitespace char is { or [, it's JSON
  local trimmed
  trimmed=$(echo "$arg" | sed 's/^[[:space:]]*//')
  local first_char="${trimmed:0:1}"

  local overlay
  if [[ "$first_char" == "{" || "$first_char" == "[" ]]; then
    overlay="$arg"
  elif [[ -f "$arg" ]]; then
    overlay=$(cat "$arg")
  else
    err "Argument is neither JSON nor a valid file path: $arg"
    exit 1
  fi

  # Validate the overlay is valid JSON
  if ! echo "$overlay" | jq empty 2> /dev/null; then
    err "Invalid JSON in merge-settings argument."
    exit 1
  fi

  # Deep merge: overlay wins for scalar values, objects are recursively merged
  local merged
  merged=$(jq -s '
    def deep_merge(a; b):
      a as $a | b as $b |
      if ($a | type) == "object" and ($b | type) == "object" then
        ($a | keys_unsorted) + ($b | keys_unsorted) | unique |
        map(. as $k |
          if ($a | has($k)) and ($b | has($k)) then
            { ($k): deep_merge($a[$k]; $b[$k]) }
          elif ($b | has($k)) then
            { ($k): $b[$k] }
          else
            { ($k): $a[$k] }
          end
        ) | add // {}
      else
        $b
      end;
    deep_merge(.[0]; .[1])
  ' "$settings" <(echo "$overlay"))

  echo "$merged" > "$settings"
  log "Merged settings into '$name'."
}

clean_env() {
  local env_dir="$1"
  local name="$2"

  if [[ ! -d "$env_dir" ]]; then
    warn "Environment '$name' doesn't exist."
    return
  fi

  warn "Removing environment '$name'..."
  rm -rf "$env_dir"
  log "Removed. Recreate with: claude-with $name --create"
}

# Handle no args
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

# Handle top-level flags
case "$1" in
  --help | -h)
    usage
    exit 0
    ;;
  --list)
    list_envs
    exit 0
    ;;
  --*)
    err "Unknown option: $1"
    usage
    exit 1
    ;;
esac

# First arg is the environment name
ENV_NAME="$1"
shift

# Validate name (alphanumeric, hyphens, underscores)
if [[ ! "$ENV_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  err "Invalid environment name: '$ENV_NAME'"
  err "Use only letters, numbers, hyphens, and underscores."
  exit 1
fi

ENV_DIR="$ENV_BASE/$ENV_NAME"

# Parse remaining args: claude-with options come before --, claude args after
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --create)
      if [[ -d "$ENV_DIR" ]]; then
        warn "Environment '$ENV_NAME' already exists."
        exit 1
      fi
      CREATE_BARE="false"
      if [[ "${2:-}" == "--bare" ]]; then
        CREATE_BARE="true"
      fi
      setup_env "$ENV_DIR" "$ENV_NAME" "$CREATE_BARE"
      exit 0
      ;;
    --clean)
      clean_env "$ENV_DIR" "$ENV_NAME"
      exit 0
      ;;
    --path)
      echo "$ENV_DIR"
      exit 0
      ;;
    --settings)
      if [[ ! -d "$ENV_DIR" ]]; then
        err "Environment '$ENV_NAME' does not exist."
        exit 1
      fi
      dump_settings "$ENV_DIR" "$ENV_NAME"
      exit 0
      ;;
    --merge-settings)
      if [[ -z "${2:-}" ]]; then
        err "Usage: claude-with $ENV_NAME --merge-settings <json|file>"
        exit 1
      fi
      if [[ ! -d "$ENV_DIR" ]]; then
        err "Environment '$ENV_NAME' does not exist."
        exit 1
      fi
      merge_settings "$ENV_DIR" "$ENV_NAME" "$2"
      exit 0
      ;;
    --)
      shift
      CLAUDE_ARGS+=("$@")
      break
      ;;
    *)
      # No --, so everything from here goes to claude
      CLAUDE_ARGS+=("$@")
      break
      ;;
  esac
done

# Environment must exist
if [[ ! -d "$ENV_DIR" ]]; then
  err "Environment '$ENV_NAME' does not exist."
  err ""
  err "Create it first:"
  err "  claude-with $ENV_NAME --create"
  err ""
  err "Available environments:"
  list_envs
  exit 1
fi

# Run Claude with this environment
log "Using environment '$ENV_NAME'"
exec env CLAUDE_CONFIG_DIR="$ENV_DIR" claude "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
