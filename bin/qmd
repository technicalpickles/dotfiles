#!/bin/sh
# Pin qmd to the Node its native deps (better-sqlite3) were built against.
# qmd is npm-installed under mise's Node 24; its better-sqlite3 binary is
# ABI-locked to that major (NODE_MODULE_VERSION 137). qmd's own launcher runs
# a bare `node` off PATH, so when something else wins PATH resolution (e.g. the
# hermes ACP feature symlinking its own Node 22 into ~/.local/bin), qmd loads a
# Node-24 module under Node 22 and crashes. Forcing Node 24 onto PATH here makes
# qmd's launch deterministic regardless of cwd, mise, or PATH order.
#
# This wrapper sits on PATH ahead of mise's node/lts/bin (via ~/.pickles/bin),
# so the bare `qmd`, the `qmd mcp` server, and the qmd-refresh LaunchAgent all
# route through it. See bean gt-n2m3.
NODE_BIN="$HOME/.local/share/mise/installs/node/24/bin"
export PATH="$NODE_BIN:$PATH"
exec "$NODE_BIN/qmd" "$@"
