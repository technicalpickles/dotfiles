#!/usr/bin/env bash
set -uo pipefail

# check-agent-ssh-key <role>
#
# Validate that the manual enrollment steps for an agent SSH identity were
# completed correctly. Complements bin/setup-agent-ssh-key.
#
# Checks:
#   1. Local key files exist with correct perms
#   2. Key is loaded in ssh-agent (via Keychain on macOS)
#   3. Agent email is verified on GitHub
#   4. Public key registered on GitHub as authentication key
#   5. Public key registered on GitHub as signing key
#   6. ~/.claude/settings.json wires GIT_CONFIG_GLOBAL to a gitconfig include
#      file that overrides user.email, core.sshCommand, and gpg.ssh.program
#   7. SSH can authenticate to github.com using this key
#   8. (work role only) the key is authorized for each org's SAML SSO
#
# Exits 0 on all-pass, 1 if anything failed.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info() { echo -e "${BLUE}$*${NC}"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
error() { echo -e "${RED}✗${NC} $*" >&2; }
die() {
  error "$*"
  exit 2
}

PASS=0
FAIL=0

check_pass() {
  success "$1"
  PASS=$((PASS + 1))
}

check_fail() {
  error "$1"
  [[ $# -gt 1 ]] && echo -e "  ${YELLOW}$2${NC}" >&2
  FAIL=$((FAIL + 1))
}

usage() {
  cat << EOF
Usage: check-agent-ssh-key <role> [--email <email>]

Validate an agent SSH identity setup. Reports pass/fail for each step of
the enrollment checklist (local files, Keychain, GitHub registration,
Claude settings). Exits 0 if all pass, 1 if any fail.

Arguments:
  role             Dotfiles role the identity belongs to (e.g. personal, work)

Options:
  --email <email>  Override the agent email address. Must match what was
                   passed to setup-agent-ssh-key. Defaults to
                   joshua.nichols+<role>-agent@gmail.com.
EOF
}

ROLE=""
EMAIL_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help | -h)
      usage
      exit 0
      ;;
    --email)
      [[ $# -lt 2 ]] && die "--email requires a value"
      EMAIL_OVERRIDE="$2"
      shift 2
      ;;
    --email=*)
      EMAIL_OVERRIDE="${1#--email=}"
      shift
      ;;
    --*)
      die "Unknown flag: $1"
      ;;
    *)
      if [[ -z "$ROLE" ]]; then
        ROLE="$1"
        shift
      else
        die "Unexpected argument: $1"
      fi
      ;;
  esac
done

if [[ -z "$ROLE" ]]; then
  usage
  exit 2
fi

if [[ ! "$ROLE" =~ ^[a-z][a-z0-9_-]*$ ]]; then
  die "Invalid role name: '$ROLE'"
fi

KEY_DIR="$HOME/.ssh/agents/$ROLE"
KEY_PATH="$KEY_DIR/id_ed25519"
PUB_PATH="$KEY_PATH.pub"
EMAIL="${EMAIL_OVERRIDE:-joshua.nichols+${ROLE}-agent@gmail.com}"
SETTINGS="$HOME/.claude/settings.json"
REQUIRED_SCOPES=("user:email" "read:public_key" "read:ssh_signing_key")

if [[ "$(uname)" != "Darwin" ]]; then
  die "This script assumes macOS (Keychain, BSD stat). Not macOS."
fi

command -v ssh-keygen > /dev/null || die "ssh-keygen not found"
command -v ssh-add > /dev/null || die "ssh-add not found"
command -v gh > /dev/null || die "gh not found (install with: brew install gh)"
command -v jq > /dev/null || die "jq not found"

# Force BSD stat; coreutils can shadow /usr/bin/stat with GNU dialect
STAT=/usr/bin/stat

echo -e "${BOLD}Checking agent SSH identity: ${ROLE}${NC}"
echo

# --- 1. Local key files ---
if [[ -f "$KEY_PATH" && -f "$PUB_PATH" ]]; then
  key_mode=$("$STAT" -f '%Lp' "$KEY_PATH")
  pub_mode=$("$STAT" -f '%Lp' "$PUB_PATH")
  if [[ "$key_mode" == "600" && "$pub_mode" == "644" ]]; then
    check_pass "Key files exist with correct perms ($KEY_PATH)"
  else
    check_fail "Key file perms wrong" "private=$key_mode (want 600), public=$pub_mode (want 644)"
  fi
else
  check_fail "Key files missing" "Run: bin/setup-agent-ssh-key $ROLE"
fi

# Everything below needs the pub key to compute fingerprint
if [[ ! -f "$PUB_PATH" ]]; then
  echo
  error "Cannot continue without $PUB_PATH"
  exit 1
fi

LOCAL_FP=$(ssh-keygen -lf "$PUB_PATH" | awk '{print $2}')

# --- 2. Key loaded in ssh-agent ---
if ssh-add -l 2> /dev/null | awk '{print $2}' | grep -Fxq "$LOCAL_FP"; then
  check_pass "Key loaded in ssh-agent (fingerprint: $LOCAL_FP)"
else
  check_fail "Key not loaded in ssh-agent" "Run: ssh-add --apple-use-keychain $KEY_PATH"
fi

# --- gh auth scope check (needed for GitHub checks) ---
# GitHub OAuth scopes form a hierarchy: admin:X implies write:X implies
# read:X. A token with admin:public_key satisfies a read:public_key
# requirement. has_scope encodes that so we don't fail on stronger scopes.
has_scope() {
  local required="$1"
  local scopes="$2"
  echo "$scopes" | grep -Fxq "$required" && return 0
  if [[ "$required" == read:* ]]; then
    local suffix="${required#read:}"
    echo "$scopes" | grep -Fxq "write:$suffix" && return 0
    echo "$scopes" | grep -Fxq "admin:$suffix" && return 0
  elif [[ "$required" == write:* ]]; then
    local suffix="${required#write:}"
    echo "$scopes" | grep -Fxq "admin:$suffix" && return 0
  fi
  return 1
}

if ! gh auth status > /dev/null 2>&1; then
  check_fail "gh is not authenticated" "Run: gh auth login"
  gh_ok=false
else
  gh_ok=true
  token_scopes=$(gh auth status 2>&1 | grep -i 'Token scopes:' | sed "s/.*Token scopes: //" | tr -d "'" | tr ',' '\n' | sed 's/^ *//;s/ *$//')
  missing=()
  for s in "${REQUIRED_SCOPES[@]}"; do
    if ! has_scope "$s" "$token_scopes"; then
      missing+=("$s")
    fi
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    check_fail "gh token missing scopes: ${missing[*]}" \
      "Run: gh auth refresh -h github.com -s $(
        IFS=,
        echo "${missing[*]}"
      )"
    gh_ok=false
  else
    check_pass "gh token has required scopes"
  fi
fi

# --- 3. Email verified on GitHub ---
if $gh_ok; then
  email_row=$(gh api user/emails 2> /dev/null | jq -r --arg e "$EMAIL" '.[] | select(.email == $e)')
  if [[ -z "$email_row" ]]; then
    check_fail "$EMAIL not registered on GitHub account" "Add at: https://github.com/settings/emails"
  elif [[ "$(echo "$email_row" | jq -r '.verified')" != "true" ]]; then
    check_fail "$EMAIL registered but not verified" "Check your inbox for the verification link"
  else
    check_pass "$EMAIL verified on GitHub"
  fi
fi

# --- 4 + 5. GitHub keys ---
# Normalize keys via fingerprint comparison
compare_fp() {
  local endpoint="$1"
  local label="$2"
  local settings_url="$3"
  local remote_fps
  remote_fps=$(gh api "$endpoint" --jq '.[].key' 2> /dev/null | while IFS= read -r key; do
    [[ -n "$key" ]] && echo "$key" | ssh-keygen -lf - 2> /dev/null | awk '{print $2}'
  done)
  if echo "$remote_fps" | grep -Fxq "$LOCAL_FP"; then
    check_pass "$label registered on GitHub"
  else
    check_fail "$label not registered on GitHub" "Upload pub key at: $settings_url"
  fi
}

if $gh_ok; then
  compare_fp "user/keys" "Authentication key" "https://github.com/settings/ssh/new"
  compare_fp "user/ssh_signing_keys" "Signing key" "https://github.com/settings/ssh/new (Key type: Signing Key)"
fi

# --- 6. ~/.claude/settings.json + gitconfig include ---
# Verify GIT_CONFIG_GLOBAL is wired to a gitconfig include file, the file
# exists, and it overrides the settings that matter: user.email (or git
# won't attribute to the agent), core.sshCommand (or ssh will use
# 1Password's IdentityAgent), and gpg.ssh.program=ssh-keygen (or signing
# falls through to 1Password's op-ssh-sign and fails).
if [[ -f "$SETTINGS" ]]; then
  git_config_global=$(jq -r '.env.GIT_CONFIG_GLOBAL // empty' "$SETTINGS")
  # Expand leading ~/ for the check (claudeconfig.sh writes absolute paths,
  # but tolerate either shape).
  expanded_path="${git_config_global/#\~\//$HOME/}"

  if [[ -z "$git_config_global" ]]; then
    check_fail "~/.claude/settings.json missing GIT_CONFIG_GLOBAL" \
      "Run: DOTPICKLES_ROLE=$ROLE ./claudeconfig.sh"
  elif [[ ! -f "$expanded_path" ]]; then
    check_fail "GIT_CONFIG_GLOBAL points at missing file: $expanded_path" \
      "Expected file at home/.gitconfig.d/claude-agent-$ROLE in the dotfiles repo"
  else
    cfg_email=$(git config --file "$expanded_path" user.email 2> /dev/null || true)
    cfg_ssh=$(git config --file "$expanded_path" core.sshCommand 2> /dev/null || true)
    cfg_gpg=$(git config --file "$expanded_path" gpg.ssh.program 2> /dev/null || true)
    # Normalize ~/ in the sshCommand value so the check accepts either form.
    cfg_ssh_expanded="${cfg_ssh//\~\//$HOME/}"

    if [[ "$cfg_email" != "$EMAIL" ]]; then
      check_fail "$expanded_path missing user.email=$EMAIL" \
        "got: '$cfg_email'"
    elif [[ "$cfg_ssh_expanded" != *"$KEY_PATH"* ]]; then
      check_fail "$expanded_path missing core.sshCommand using $KEY_PATH" \
        "got: '$cfg_ssh'"
    elif [[ "$cfg_gpg" != "ssh-keygen" ]]; then
      check_fail "$expanded_path missing gpg.ssh.program=ssh-keygen" \
        "got: '$cfg_gpg' (1Password's op-ssh-sign will block agent signing)"
    else
      check_pass "Agent gitconfig include wired up ($expanded_path)"
    fi
  fi
else
  check_fail "~/.claude/settings.json not found" "Run: DOTPICKLES_ROLE=$ROLE ./claudeconfig.sh"
fi

# --- 7. SSH auth to github.com using THIS key ---
# GitHub returns "Hi <user>!" on success, exit code 1 (expected, no shell).
#
# Two non-obvious things this guards against:
#   - -F /dev/null: ~/.ssh/config's `Host *` adds `IdentityFile ~/.ssh/id_ed25519`
#     (the human laptop key). IdentityFile is additive and IdentitiesOnly=yes does
#     NOT drop config-supplied identities -- only extra agent-offered ones. Without
#     -F, ssh offers the laptop key first, the server accepts it, and the test
#     "passes" via the wrong key. Because both keys live on the same GitHub account,
#     the "Hi <user>!" greeting is identical either way, so the username alone can't
#     catch it. -F /dev/null makes the explicit `-i` the only candidate.
#   - fingerprint assertion: we parse the -v trace's "Server accepts key" line and
#     require the accepted fingerprint to equal THIS key's. Belt-and-suspenders so a
#     future config leak can never let a different key satisfy the check silently.
info "Testing SSH auth to github.com (this may take a second)..."
ssh_out=$(ssh -v -F /dev/null -i "$KEY_PATH" \
  -o IdentitiesOnly=yes \
  -o IdentityAgent=SSH_AUTH_SOCK \
  -o StrictHostKeyChecking=accept-new \
  -o ConnectTimeout=10 \
  -T git@github.com 2>&1 || true)
accepted_fp=$(echo "$ssh_out" | grep "Server accepts key:" | grep -oE 'SHA256:[A-Za-z0-9+/]+' | head -1)
if echo "$ssh_out" | grep -q "successfully authenticated"; then
  gh_user=$(echo "$ssh_out" | sed -n 's/^Hi \([^!]*\)!.*/\1/p')
  if [[ "$accepted_fp" == "$LOCAL_FP" ]]; then
    check_pass "SSH auth to github.com works with this key (as: $gh_user)"
  else
    check_fail "SSH auth succeeded but with the WRONG key" \
      "server accepted ${accepted_fp:-<unknown>}, expected this key $LOCAL_FP -- check ~/.ssh/config IdentityFile leakage"
  fi
else
  check_fail "SSH auth to github.com failed" \
    "$(echo "$ssh_out" | grep -iE 'denied|permission|error|fatal' | head -3)"
fi

# --- 8. Per-org SAML SSO authorization (work role only) ---
# Authenticating to github.com (step 7) only proves the key maps to the
# account. Org-owned repos behind SAML SSO additionally require the key to be
# *authorized for that org* -- a separate, per-org, browser-only grant
# (github.com/settings/keys -> Configure SSO). It is invisible to `ssh -T` and
# not exposed via gh/API, so the only way to verify it is to actually reach an
# org repo. An unauthorized key gets a loud "enabled or enforced SAML SSO"
# error from `git ls-remote` while still passing step 7.
#
# Only the work role has org-scoped access. The personal/home role uses a
# personal identity against personal repos with no org SSO, so it has no org
# list and this whole block is skipped for it.
declare -a SSO_ORG_PROBES
case "$ROLE" in
  work)
    # org:probe-repo -- any stable private repo in the org works as a canary.
    SSO_ORG_PROBES=("Gusto:Gusto/web" "guideline-app:guideline-app/bamboo-cli")
    ;;
  *)
    SSO_ORG_PROBES=()
    ;;
esac

if [[ ${#SSO_ORG_PROBES[@]} -gt 0 ]]; then
  info "Checking per-org SAML SSO authorization (this may take a few seconds)..."
  # Mirror the live agent sshCommand: -F /dev/null so ~/.ssh/config's additive
  # `Host *` IdentityFile can't leak the human laptop key into the probe.
  agent_ssh="ssh -F /dev/null -i $KEY_PATH -o IdentitiesOnly=yes -o IdentityAgent=SSH_AUTH_SOCK -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10"
  for probe in "${SSO_ORG_PROBES[@]}"; do
    org="${probe%%:*}"
    repo="${probe#*:}"
    ls_out=$(GIT_SSH_COMMAND="$agent_ssh" git ls-remote "git@github.com:${repo}.git" HEAD 2>&1 || true)
    if echo "$ls_out" | grep -q "enabled or enforced SAML SSO"; then
      check_fail "$org: key not authorized for SAML SSO" \
        "Authorize at https://github.com/settings/keys -> Configure SSO -> $org"
    elif echo "$ls_out" | grep -Eq "^[0-9a-f]{40}[[:space:]]+HEAD"; then
      check_pass "$org: key authorized for SAML SSO (probed $repo)"
    else
      check_fail "$org: SSO probe inconclusive (could not reach $repo)" \
        "$(echo "$ls_out" | head -2)"
    fi
  done
fi

# --- Summary ---
echo
if [[ $FAIL -eq 0 ]]; then
  echo -e "${GREEN}${BOLD}All $PASS checks passed.${NC}"
  exit 0
else
  echo -e "${RED}${BOLD}$FAIL failed${NC}, ${GREEN}$PASS passed${NC}"
  exit 1
fi
