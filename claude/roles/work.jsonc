{
  // Work role settings (values from live settings, not stale source files)
  "awsAuthRefresh": "aws sso login --profile $AWS_PROFILE",
  "env": {
    // too many
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },

  // Work-specific permissions
  "permissions": {
    "allow": [
      "Bash(bin/rspec:*)",
      "Bash(bin/rubocop:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(bundle install)",
      "Bash(npx bktide build:*)",
      "Bash(npx bktide)",
      "Bash(npx bktide:*)",
    ],
  },

  // Work-specific sandbox (source: agent-safehouse)
  "sandbox": {
    "network": {
      "allowedHosts": ["portal.sso.us-west-2.amazonaws.com"],
    },
  },

  // Pickleton session tracking hooks (global so they fire in all directories,
  // not just when Claude starts in ~/pickleton itself)
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.pickles/bin/pickletown claude-hook session-start",
          },
        ],
      },
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.pickles/bin/pickletown claude-hook skill-session-tracking",
          },
        ],
      },
    ],
  },
}
