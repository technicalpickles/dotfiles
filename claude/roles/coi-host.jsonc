{
  // An OrbStack VM running incus as a COI (Code on Incus) host. Set explicitly by
  // pickled-coi's vm/setup.sh, never auto-detected: nothing at runtime
  // distinguishes this VM from a laptop, so dotpickles_detect_role's early
  // return (functions.sh) relies on DOTPICKLES_ROLE already being set in the
  // environment. This is a placeholder so DOTPICKLES_ROLE=coi-host resolves to
  // a real role file and doesn't trip claudeconfig.sh's fail-loud missing-role
  // guard (ADR 0031).
  //
  // Agent identity: deliberately reuses the home agent identity rather than
  // minting a coi-host one. This VM is an extension of the user's personal
  // machine, and a separate identity would need its own GitHub enrollment on
  // every VM rebuild, which fights the rebuild-from-scratch goal this VM
  // exists to prove. The private key is copied into the VM by pickled-coi's
  // vm/auth.sh (copying was chosen over the alternatives).
  //
  // See claude/roles/home.jsonc for the full GIT_CONFIG_GLOBAL explanation.
  "env": {
    "GIT_CONFIG_GLOBAL": "~/.gitconfig.d/claude-agent-home",
  },

  // No other overrides yet. Add sandbox rules here if a concrete COI-host
  // workflow needs them -- don't copy home's sandbox block as-is, its
  // allowWrite is a macOS Library path and its allowedHosts are Mac-specific.
}
