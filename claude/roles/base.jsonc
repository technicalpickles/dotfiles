{
  // Base settings
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
  },
  "includeCoAuthoredBy": true,

  // without this, thinking isn't displayed in interactive mode or persisted to
  // session logs
  "showThinkingSummaries": true,

  // Permissions: base safety rules
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(rm -rf .DS_Store)",
      "Bash(rm -rf .cache)",
      "Bash(rm -rf .coverage)",
      "Bash(rm -rf .gradle)",
      "Bash(rm -rf .next)",
      "Bash(rm -rf .pytest_cache)",
      "Bash(rm -rf .rspec_cache)",
      "Bash(rm -rf .tmp)",
      "Bash(rm -rf ./build)",
      "Bash(rm -rf ./coverage)",
      "Bash(rm -rf ./dist)",
      "Bash(rm -rf ./node_modules)",
      "Bash(rm -rf ./out)",
      "Bash(rm -rf ./pkg)",
      "Bash(rm -rf ./target)",
      "Bash(rm -rf ./temp)",
      "Bash(rm -rf ./tmp)",
      "Bash(rm -rf ./vendor)",
      "Bash(rm -rf build)",
      "Bash(rm -rf coverage)",
      "Bash(rm -rf dist)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf out)",
      "Bash(rm -rf pkg)",
      "Bash(rm -rf target)",
      "Bash(rm -rf temp)",
      "Bash(rm -rf tmp)",
      "Bash(sudo docker:*)",
      "Bash(sudo journalctl:*)",
      "Bash(sudo systemctl disable:*)",
      "Bash(sudo systemctl enable:*)",
      "Bash(sudo systemctl reload:*)",
      "Bash(sudo systemctl restart:*)",
      "Bash(sudo systemctl start:*)",
      "Bash(sudo systemctl status:*)",
      "Bash(sudo systemctl stop:*)",
    ],
    "ask": [
      "Bash(sudo chmod:*)",
      "Bash(sudo chown:*)",
      "Bash(sudo chgrp:*)",
      "Bash(sudo mkdir:*)",
      "Bash(sudo mv:*)",
      "Bash(sudo cp:*)",
      "Bash(sudo ln:*)",
      "Bash(sudo kill:*)",
      "Bash(sudo killall:*)",
      "Bash(sudo shutdown:*)",
      "Bash(sudo reboot:*)",
      "Bash(sudo halt:*)",
      "Bash(sudo apt-get:*)",
      "Bash(sudo yum:*)",
      "Bash(sudo dnf:*)",
    ],
    "deny": [
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(sudo rm -rf:*)",
      "Bash(sudo dd:*)",
      "Bash(sudo mkfs:*)",
      "Bash(sudo fdisk:*)",
      "Bash(sudo parted:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ..:*)",
      "Bash(rm -rf ../*:*)",
    ],
  },

  // Sandbox: base config (source: agent-safehouse)
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    // (macOS only) Allow access to the system TLS trust service
    // (com.apple.trustd.agent). Required for Go-based tools like gh,
    // gcloud, and terraform to verify TLS certificates when using
    // httpProxyPort with a MITM proxy and custom CA.
    "enableWeakerNetworkIsolation": true,
    "network": {
      // Permits git commit signing, git fsmonitor, Docker socket, etc.
      "allowAllUnixSockets": true,
      "allowedHosts": ["api.anthropic.com", "code.claude.com"],
      // local dev servers, and other things that are weird and listen (clippy
      // --fix for some reason??)
      "allowLocalBinding": true,
    },
    "filesystem": {
      "allowWrite": [
        // rtk (CLI proxy) needs to write its state/config here
        "~/Library/Application Support/rtk",
      ],
    },
  },
}
