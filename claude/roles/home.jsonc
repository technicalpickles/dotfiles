{
  // Home role agent identity (see ADR 0031).
  // Every Claude Code session under DOTPICKLES_ROLE=home commits and
  // pushes as a dedicated agent identity instead of the user's 1Password
  // GPG flow, which requires interactive approval.
  //
  // The key lives at ~/.ssh/agents/home to match the role (ADR 0039). The
  // email stays joshua.nichols+personal-agent@gmail.com -- the GitHub-enrolled
  // "personal-agent" address, kept to preserve the Verified-badge enrollment
  // until/unless it's re-enrolled under a home-named address.
  //
  // Prerequisite (already done on this machine): recreate with
  // `bin/setup-agent-ssh-key home --email joshua.nichols+personal-agent@gmail.com`
  // then complete the printed GitHub enrollment steps.
  // GIT_CONFIG_GLOBAL swaps in an agent-specific gitconfig for Claude-spawned
  // shells. The target file [include]s ~/.gitconfig then overrides user.email,
  // core.sshCommand, and gpg.ssh.program (resets 1Password's op-ssh-sign to
  // ssh-keygen). Leading ~/ is expanded by claudeconfig.sh before writing
  // settings.json (GIT_CONFIG_GLOBAL itself does not expand ~).
  "env": {
    "GIT_CONFIG_GLOBAL": "~/.gitconfig.d/claude-agent-home",
  },

  "sandbox": {
    "network": {
      "allowedHosts": ["brineworks.tail2023b7.ts.net"],
    },
    "filesystem": {
      "allowWrite": ["~/Library/Caches/f3d"],
    },
  },
}
