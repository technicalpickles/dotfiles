{
  // Personal role agent identity (see ADR 0031).
  // Every Claude Code session under DOTPICKLES_ROLE=personal commits and
  // pushes as a dedicated agent identity instead of the user's 1Password
  // GPG flow, which requires interactive approval.
  //
  // Prerequisite: run `bin/setup-agent-ssh-key personal` once and complete
  // the printed GitHub enrollment steps.
  "env": {
    "GIT_AUTHOR_EMAIL": "joshua.nichols+personal-agent@gmail.com",
    "GIT_COMMITTER_EMAIL": "joshua.nichols+personal-agent@gmail.com",
    // IdentityAgent=SSH_AUTH_SOCK bypasses the 1Password IdentityAgent set for Host * (ssh/config.d/auth)
    "GIT_SSH_COMMAND": "ssh -i ~/.ssh/agents/personal/id_ed25519 -o IdentitiesOnly=yes -o IdentityAgent=SSH_AUTH_SOCK",
    // Override gpg config without touching ~/.gitconfig; leaves interactive shells using 1Password GPG.
    // gpg.ssh.program must be reset to ssh-keygen; global config points at 1Password's op-ssh-sign,
    // which doesn't know about keys outside the 1Password vault.
    "GIT_CONFIG_COUNT": "4",
    "GIT_CONFIG_KEY_0": "user.signingkey",
    "GIT_CONFIG_VALUE_0": "~/.ssh/agents/personal/id_ed25519.pub",
    "GIT_CONFIG_KEY_1": "gpg.format",
    "GIT_CONFIG_VALUE_1": "ssh",
    "GIT_CONFIG_KEY_2": "commit.gpgsign",
    "GIT_CONFIG_VALUE_2": "true",
    "GIT_CONFIG_KEY_3": "gpg.ssh.program",
    "GIT_CONFIG_VALUE_3": "ssh-keygen",
  },

  "sandbox": {
    "network": {
      "allowedHosts": ["brineworks.tail2023b7.ts.net"],
    },
    "filesystem": {
      "allowWrite": ["~/Library/Caches/f3d"],
    },
  },
}
