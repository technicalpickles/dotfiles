{
  // Git operations - comprehensive coverage for daily workflow
  "permissions": {
    "allow": [
      // Staging and committing
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",

      // Branching and navigation
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git worktree:*)",

      // Synchronization
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",

      // History rewriting (non-destructive)
      "Bash(git cherry-pick:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",

      // Safer force-push alternative
      "Bash(git push --force-with-lease:*)",

      // Safe reset patterns - align with remote
      "Bash(git reset --hard origin/*:*)",
      "Bash(git reset --hard upstream/*:*)",
      "Bash(git reset --hard HEAD:*)",

      // Clean dry-run (always safe)
      "Bash(git clean -n:*)",
      "Bash(git clean --dry-run:*)",

      // Inspection and queries
      "Bash(git check-ignore:*)",
      "Bash(git config:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-remote:*)",
      "Bash(git ls-tree:*)",
      "Bash(git merge-base:*)",
      "Bash(git rev-parse:*)",
      "Bash(git shortlog:*)",
      "Bash(git show-ref:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",

      // File operations
      "Bash(git mv:*)",
      "Bash(git rm:*)",

      // Tags and submodules
      "Bash(git submodule:*)",
      "Bash(git tag:*)",

      // hk git hooks tool (from old web.json)
      "WebFetch(domain:hk.jdx.dev)"
    ],

    // Operations that warrant confirmation
    "ask": [
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ],

    // Destructive operations that should never be auto-allowed
    "deny": [
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push -f origin master:*)",
      "Bash(git push --force upstream main:*)",
      "Bash(git push --force upstream master:*)",
      "Bash(git push -f upstream main:*)",
      "Bash(git push -f upstream master:*)"
    ]
  },

  // source: agent-safehouse
  "sandbox": {
    "network": {
      "allowedHosts": [
        "hk.jdx.dev"
      ]
    }
  }
}
