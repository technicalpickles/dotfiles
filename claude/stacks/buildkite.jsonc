{
  // Buildkite CI (source: agent-safehouse)
  "sandbox": {
    "network": {
      "allowedHosts": [
        "api.buildkite.com",
        "buildkite.com",
        "buildkiteartifacts.com",
      ],
    },
    "filesystem": {
      "allowWrite": ["~/.local/state/bktide", "~/.cache/bktide"],
    },
  },
}
